<Window x:Class="_2023_06_01_d.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2023_06_01_d"
        mc:Ignorable="d"
        Title="Nadaj przesyłkę, PESEL: 01234567890" 
        Height="320" 
        Width="580"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.65*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="7*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0"
                    Grid.Row="0"
                    Orientation="Vertical"
                    Margin="35, 15, 0, 10">
            <GroupBox Header="Rodzaj przesyłki"
                      Margin="0, 0, 40, 10">
                <StackPanel Orientation="Vertical"
                            Margin="10">
                    <RadioButton Content="Pocztówka"
                                 GroupName="packageType"
                                 Margin="0, 0, 0, 10"
                                 x:Name="radioButtonPostcard" />

                    <RadioButton Content="List"
                                 GroupName="packageType"
                                 Margin="0, 0, 0, 10"
                                 x:Name="radioButtonLetter" />

                    <RadioButton Content="Paczka"
                                 GroupName="packageType"
                                 x:Name="radioButtonPackage" />
                </StackPanel>
            </GroupBox>

            <Button Content="Sprawdź Cenę"
                    Margin="0, 0, 40, 10"
                    Click="CheckPrice" />

            <StackPanel Orientation="Horizontal">
                <Image Source="/images/pocztowka.png"
                       Width="100"
                       Margin="0, 0, 20, 0"
                       x:Name="imagePackageType" />

                <Label Content="Cena: "
                       FontWeight="Bold"
                       FontSize="20"
                       x:Name="labelPrice" />
            </StackPanel>
        </StackPanel>

        <Button Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="1"
                Height="25"
                Margin="35, 0"
                Content="Zatwierdź"
                Click="Confirm" />

        <StackPanel Grid.Column="1"
                    Grid.Row="0"
                    Orientation="Vertical"
                    Margin="20, 15, 35, 0">
            <GroupBox Header="Dane adresowe">
                <StackPanel Orientation="Vertical"
                            Margin="10">
                    <Label Content="Ulica z numerem" />

                    <TextBox Margin="0, 0, 0, 5" />

                    <Label Content="Kod pocztowy" />

                    <TextBox Margin="0, 0, 125, 5"
                             x:Name="textBoxPostalCode" />

                    <Label Content="Miasto" />

                    <TextBox />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
