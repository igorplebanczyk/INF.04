<Window x:Class="_2024_czerwiec_02_desktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2024_czerwiec_02_desktopowa"
        mc:Ignorable="d"
        Title="Moje dźwięki, Wykonał: 12345678901" Height="300" Width="1150" ResizeMode="NoResize" Background="SeaGreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.25*" />
            <ColumnDefinition Width="1.85*" />
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="1.25*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Height="70"
                Background="Transparent"
                HorizontalAlignment="Center"
                Click="SwitchLeft">
            <Image Source="/images/obraz3.png" />
        </Button>

        <Canvas Grid.Column="1"
                Margin="15, 0, 0, 20">
            <Image Canvas.Top="15"
                   Height="150"
                   Source="/images/obraz.png" />

            <Label Canvas.Bottom="0"
                   Canvas.Left="0"
                   Content=""
                   FontSize="20"
                   Foreground="#61D918"
                   x:Name="labelDownloadNumber" />

            <Button Canvas.Bottom="0"
                Canvas.Right="0"
                Content="Pobierz"
                FontWeight="Bold" 
                FontSize="20"
                Background="#61D918"
                Click="Download" />
        </Canvas>

        <Canvas Grid.Column="2">
            <Label Canvas.Top="30"
                   Content=""
                   FontSize="50"
                   Foreground="White"
                   x:Name="labelArtist" />

            <Label Canvas.Top="95"
                   Content=""
                   FontSize="30"
                   FontStyle="Italic"
                   Foreground="white"
                   x:Name="labelAlbum" />

            <Label Canvas.Top="145"
                   Content=""
                   FontSize="20"
                   Foreground="#61D918"
                   x:Name="labelSongsNumber" />

            <Label Canvas.Top="145"
                   Canvas.Left="150"
                   Content=""
                   FontSize="20"
                   Foreground="#61D918"
                   x:Name="labelYear" />
        </Canvas>

        <Button Grid.Column="3"
                Height="70"
                Background="Transparent"
                HorizontalAlignment="Center"
                Click="SwitchRight">
            <Image Source="/images/obraz2.png" />
        </Button>

    </Grid>
</Window>
