<Window x:Class="_2024_styczen_01_desktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2024_styczen_01_desktopowa"
        mc:Ignorable="d"
        Title="Wprowadzenie danych do paszportu. Wykonał 12345678901" Height="350" Width="800" Background="CadetBlue">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" 
                    Grid.Row="0"
                    Margin="0, 20, 0, 0">
            <DockPanel Margin="20, 5"
                       LastChildFill="False">
                <Label Content="Numer" 
                       FontSize="14"
                       DockPanel.Dock="Left" />

                <TextBox Width="200"
                         VerticalAlignment="Center"                        
                         DockPanel.Dock="Right"
                         Background="Azure"
                         LostFocus="NumberTextBoxLostFocus"
                         x:Name="TextBoxNumber" />
            </DockPanel>

            <DockPanel Margin="20, 5"
                       LastChildFill="False">
                <Label Content="Imię" 
                       FontSize="14"
                       DockPanel.Dock="Left" />

                <TextBox Width="200"
                         VerticalAlignment="Center"
                         DockPanel.Dock="Right"
                         Background="Azure"
                         x:Name="TextBoxName" />
            </DockPanel>

            <DockPanel Margin="20, 5"
                       LastChildFill="False">
                <Label Content="Nazwisko" 
                       FontSize="14"
                       DockPanel.Dock="Left" />

                <TextBox Width="200"
                         VerticalAlignment="Center"
                         DockPanel.Dock="Right"
                         Background="Azure"
                         x:Name="TextBoxLastName" />
            </DockPanel>
        </StackPanel>

        <GroupBox Grid.Column="0"
                  Grid.Row="1" 
                  BorderBrush="White"
                  Margin="20, 0, 0, 20"
                  Header="Kolor oczu"
                  FontSize="14">
            <StackPanel Margin="15">
                <RadioButton GroupName="EyeColor"
                             Content="niebieskie" 
                             IsChecked="True"
                             x:Name="RadioButtonBlue"
                             Margin="0, 0, 0, 5" />

                <RadioButton GroupName="EyeColor"
                             Content="zielone"
                             x:Name="RadioButtonGreen"
                             Margin="0, 5" />

                <RadioButton GroupName="EyeColor"
                             Content="piwne"
                             x:Name="RadioButtonBrown"
                             Margin="0, 5, 0, 0" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Column="1"
                    Grid.Row="0"
                    Grid.RowSpan="2">
            <Grid Margin="20, 30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/images/000-zdjecie.jpg"
                       x:Name="ImagePerson"
                       Height="180" />

                <Image Grid.Column="1" 
                       Source="/images/000-odcisk.jpg"
                       x:Name="ImageFingerprint"
                       Height="180" />
            </Grid>

            <Button Content="OK"
                    Margin="80, 20"
                    Height="35"
                    Background="Azure"
                    Click="OkButtonClick" />
        </StackPanel>
    </Grid>
</Window>