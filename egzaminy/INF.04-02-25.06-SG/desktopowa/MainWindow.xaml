<Window x:Class="_2025_czerwiec_02_desktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2025_czerwiec_02_desktopowa"
        mc:Ignorable="d"
        Title="Szyfrowanie. Wykonane przez 12345678901" Height="450" Width="800" ResizeMode="NoResize" Background="CadetBlue">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2.5*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" 
                    Orientation="Vertical"
                    Margin="10">
            <TextBlock Text="Podaj wartość klucza"
                       FontSize="24"
                       Foreground="AntiqueWhite" />

            <TextBox Margin="130, 30"
                     x:Name="textBoxKey" />

            <TextBlock Text="Podaj tekst"
                       FontSize="24"
                       Foreground="AntiqueWhite" />

            <TextBox Margin="10"
                     Height="230"
                     TextWrapping="Wrap"
                     x:Name="textBoxText" />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Zaszyfruj"
                Background="LightBlue"
                Width="60"
                Height="22"
                Click="Encrypt" />

        <StackPanel Grid.Column="2"
                    Orientation="Vertical"
                    Margin="10">
            <TextBlock Text="Tekst zaszyfrowany"
                       FontSize="24"
                       Foreground="AntiqueWhite" />

            <Border Height="275"
                    Margin="10, 25"
                    BorderBrush="AntiqueWhite"
                    BorderThickness="3"
                    CornerRadius="20">
                <TextBlock Text="" 
                           FontSize="16"
                           Foreground="AliceBlue"
                           Margin="20"
                           x:Name="textBlockEncrypted" />
            </Border>

            <Button Content="Zapisz szyfr w pliku"
                    Background="LightBlue"
                    Height="28"
                    Width="200"
                    Click="SaveToFile" />
        </StackPanel>
    </Grid>
</Window>
