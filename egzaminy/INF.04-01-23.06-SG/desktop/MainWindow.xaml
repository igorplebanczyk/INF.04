<Window x:Class="_2023_czerwiec_01_desktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2023_czerwiec_01_desktopowa"
        mc:Ignorable="d"
        Title="Nadaj przesyłkę, PESEL: " 
        Height="350" 
        Width="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0"
                    Grid.Row="0">
            <GroupBox Header="Rodzaj przesyłki"
                      Margin="20, 20, 50, 10">
                <StackPanel Margin="5, 5, 90, 5">
                    <RadioButton GroupName="Type" 
                                 Content="Pocztówka"
                                 IsChecked="True"
                                 x:Name="RadioButtonPostcard"
                                 Margin="0, 0, 0, 5" />

                    <RadioButton GroupName="Type" 
                                 Content="List"
                                 x:Name="RadioButtonLetter"
                                 Margin="0, 5" />

                    <RadioButton GroupName="Type" 
                                 Content="Paczka"
                                 x:Name="RadioButtonPackage"
                                 Margin="0, 5, 0 , 0" />
                </StackPanel>
            </GroupBox>

            <Button Content="Sprawdź cenę"
                    Margin="20, 0, 50, 0"
                    Click="CheckPriceButton" />

            <DockPanel Margin="20"
                       LastChildFill="False">
                <Image Source="/images/pocztowka.png"
                       x:Name="ImageType"
                       DockPanel.Dock="Left"
                       Height="80"/>

                <Label Content="Cena: "
                       x:Name="LabelPrice"
                       FontWeight="Bold"
                       FontSize="18"
                       DockPanel.Dock="Right" />
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0">
            <GroupBox Header="Dane adresowe"
                      Margin="20">
                <StackPanel Margin="10, 5, 10, 10">
                    <Label Content="Ulica z numerem" 
                           Margin="0, 0, 120, 0" />

                    <TextBox Margin="0, 0, 0, 5"/>

                    <Label Content="Kod pocztowy" />

                    <TextBox Margin="0, 0, 120, 5"
                             x:Name="TextBoxPostalCode"/>

                    <Label Content="Miasto" />

                    <TextBox />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Button Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="1" 
                Margin="20, 10, 20, 20"
                Content="Zatwierdź"
                Click="ConfirmButtonClick" />
    </Grid>
</Window>
