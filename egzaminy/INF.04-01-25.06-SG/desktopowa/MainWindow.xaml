<Window x:Class="_2025_czerwiec_01_desktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2025_czerwiec_01_desktopowa"
        mc:Ignorable="d"
        Title="Wzornik kolorów RGB. Wykonał 12345678901" Height="450" Width="800" ResizeMode="NoResize" Background="Cornsilk">
    <StackPanel Orientation="Vertical">
        <Rectangle Width="750"
                   Height="75"
                   Margin="30"
                   Fill="White"
                   x:Name="rectangleColor" />


        <TextBlock Text="Dobierz kolor suwakami i zapisz przyciskiem:"
                   Margin="30, 15, 30, 10" />

        <StackPanel Orientation="Horizontal" Margin="30, 5, 30, 5">
            <Label Content="R" />

            <Slider Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Value="255"
                    Width="650"
                    Margin="5, 0, 5 , 0"
                    VerticalAlignment="Center"
                    x:Name="sliderR"
                    ValueChanged="SliderValueChanged" />

            <Label Content="{Binding ElementName=sliderR, Path=Value}" 
                   Margin="10, 0, 5, 0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="30, 5, 30, 5">
            <Label Content="G" />

            <Slider Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Value="255"
                    Width="650"
                    Margin="5, 0, 5 , 0"
                    VerticalAlignment="Center"
                    x:Name="sliderG"
                    ValueChanged="SliderValueChanged" />

            <Label Content="{Binding ElementName=sliderG, Path=Value}" 
                   Margin="10, 0, 5, 0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="30, 5, 30, 5">
            <Label Content="B" />

            <Slider Minimum="0"
                    Maximum="255"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Value="255"
                    Width="650"
                    Margin="5, 0, 5 , 0"
                    VerticalAlignment="Center"
                    x:Name="sliderB"
                    ValueChanged="SliderValueChanged" />

            <Label Content="{Binding ElementName=sliderB, Path=Value}" 
                   Margin="10, 0, 5, 0" />
        </StackPanel>

        <Button Content="Pobierz"
                Background="Peru"
                Width="165"
                Height="25"
                x:Name="buttonDownload"
                Click="Download" />

        <Label Content="255, 255, 255" 
               Background="White"
               Width="165"
               Height="25"
               Margin="0, 30, 0, 0"
               x:Name="labelColor" />
    </StackPanel>
</Window>
