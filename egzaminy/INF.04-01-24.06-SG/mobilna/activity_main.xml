<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/beige"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:background="@color/brown"
        android:textColor="@color/white"
        android:textSize="24dp"
        android:text="Gra w kości. Autor 12345678901" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:text="RZUĆ KOŚĆMI"
        android:id="@+id/button_throw" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:background="@color/white">
        
        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="9dp"
            android:adjustViewBounds="true"
            android:src="@drawable/question"
            android:id="@+id/image_view_dice_1" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginVertical="9dp"
            android:adjustViewBounds="true"
            android:src="@drawable/question"
            android:id="@+id/image_view_dice_2" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="9dp"
            android:adjustViewBounds="true"
            android:src="@drawable/question"
            android:id="@+id/image_view_dice_3" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginVertical="9dp"
            android:adjustViewBounds="true"
            android:src="@drawable/question"
            android:id="@+id/image_view_dice_4" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="9dp"
            android:adjustViewBounds="true"
            android:src="@drawable/question"
            android:id="@+id/image_view_dice_5" />
        
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:text="Wynik tego losowania:"
        android:id="@+id/text_view_draw_score"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:text="Wynik gry:"
        android:id="@+id/text_view_game_score"/>

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:text="RESETUJ WYNIK"
        android:id="@+id/button_reset" />

</LinearLayout>